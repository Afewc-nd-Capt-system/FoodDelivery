# ===========================================
# VibeChops Environment Variables
# ===========================================
# Copy this to .env and fill in all values

# ===================
# SERVER
# ===================
NODE_ENV=development
PORT=5000

# ===================
# MONGODB
# ===================
MONGODB_URI=mongodb://localhost:27017/food-delivery

# ===================
# REDIS (Optional - falls back gracefully)
# ===================
REDIS_URL=redis://localhost:6379

# ===================
# JWT & AUTH
# ===================
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars-change-in-production
DISABLE_MFA=false

# ===================
# PAYSTACK PAYMENTS
# ===================
PAYSTACK_SECRET_KEY=sk_test_your_key_here
PAYSTACK_PUBLIC_KEY=pk_test_your_key_here
PAYSTACK_WEBHOOK_SECRET=your_webhook_signing_key_here

# ===================
# EMAIL (Nodemailer)
# ===================
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password

# ===================
# FILE UPLOADS (Optional)
# ===================
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# ===================
# SECURITY
# ===================
HCAPTCHA_SECRET=your-hcaptcha-secret-key
DISABLE_RATE_LIMIT=false
DISABLE_MFA=false

# ===================
# FRONTEND URLs
# ===================
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:5000

# ===================
# DEBUG (Development only)
# ===================
DEBUG=false
LOG_LEVEL=info

# ===================
# HAVE I BEEN PWNED (Optional)
# ===================
HIBP_API_KEY=your-hibp-api-key-optional